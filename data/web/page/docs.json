        "nama": "DonatJS — Ekosistem & Dokumentasi",
        "tagline": "5 layer. 16 file. Satu ekosistem yang kohesif.",
        "deskripsi": "Panduan lengkap ekosistem DonatJS v2.2.\nDari setup pertama hingga aplikasi produksi.\nSetiap komponen punya narasi, docs, dan demo tersendiri.",
        "icon": "book/150/var(--pColor)-var(--pLightColor)/1/float",
        "cta": [
          { "text": "Quick Start",  "url": "#quickstart",         "icon": "lightning" },
          { "text": "5 Layer",      "url": "#layers",             "icon": "app"       },
          { "text": "Demo",         "url": "web/page/portal-demo","icon": "eye"       }
        ]
      }
    },

    {
      "section": "code",
      "caption": "Quick Start — Dari Nol ke Aplikasi dalam 5 Menit",
      "lang": "html",
      "colorPreset": "nord",
      "lineNumbers": true,
      "code": "<!DOCTYPE html>\n<html lang=\"id\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <!-- 1. CSS — urutan penting -->\n  <link rel=\"stylesheet\" href=\"/al/svg/svg.css\">\n  <link rel=\"stylesheet\" href=\"/al/core/donat.css\">\n  <link rel=\"stylesheet\" href=\"/al/skin/skin.css\">\n</head>\n<body>\n  <!-- 2. Layout DOM wajib -->\n  <div id=\"modal\"  class=\"hide depan\"></div>\n  <div id=\"bawah\"  class=\"toast hide\">info</div>\n  <div id=\"panel-container\"></div>\n  <div id=\"menu\" class=\"menu\">\n    <ul id=\"leftmenu\">\n      <li data-info=\"web/page/home\"><img data-src=\"home\"> Home</li>\n    </ul>\n  </div>\n  <div id=\"main\" class=\"main\">\n    <div id=\"topmenu\" class=\"topmenu\"></div>\n    <div id=\"content\" class=\"content\"></div>\n  </div>\n\n  <!-- 3. JS — urutan wajib -->\n  <script src=\"/al/skin/skin.js\"></script>\n  <script src=\"/al/core/donat.js\"></script>\n  <script src=\"/al/ui/ui.js\"></script>\n  <script src=\"/al/svg/svg.js\"></script>\n\n  <!-- 4. Bootstrap -->\n  <script>\n    // Config\n    const config = {\n      api: 0,\n      getdata: (id) => `data/${id}.json`,\n    };\n\n    // Controller\n    window.web = {\n      controller: {\n        page: (id) => ui.render.page(config.getdata(id))\n      }\n    };\n\n    // Menu listener\n    d.gebi('leftmenu').addEventListener('click', (e) => {\n      const li = e.target.closest('li');\n      if (li) navigate(li.getAttribute('data-info'));\n    });\n\n    // Tema & ikon\n    Theme.set('donat', 'hijau', 'framework');\n    loadSVGLibraries(['/al/svg/svg.json']);\n  </script>\n</body>\n</html>"
    },

    {
      "section": "code",
      "caption": "Halaman JSON Pertama — data/web/page/home.json",
      "lang": "json",
      "colorPreset": "dracula",
      "code": "{\n  \"page\": \"home\",\n  \"data\": [\n    {\n      \"section\": \"header\",\n      \"content\": {\n        \"nama\":    \"Selamat Datang\",\n        \"tagline\": \"Aplikasi saya berjalan.\",\n        \"deskripsi\": \"Dibangun dengan DonatJS.\",\n        \"icon\": \"donat/150/var(--pColor)/1/float\"\n      }\n    },\n    {\n      \"section\": \"stats\",\n      \"caption\": \"Fitur Utama\",\n      \"content\": [\n        { \"id\":1, \"nama\":\"Produk\", \"isi\":\"Kelola produk\", \"icon\":\"box/150\",   \"url\":\"inv/page/inv\" },\n        { \"id\":2, \"nama\":\"Kasir\",  \"isi\":\"Proses order\", \"icon\":\"cart/150\",  \"url\":\"pos/page/pos\" },\n        { \"id\":3, \"nama\":\"Laporan\",\"isi\":\"Lihat data\",   \"icon\":\"chart/150\", \"url\":\"web/page/report\" }\n      ]\n    },\n    {\n      \"section\": \"btn\",\n      \"btn\": [\n        { \"text\":\"Buka Kasir\", \"url\":\"pos/page/pos\", \"icon\":\"cart/24\" }\n      ]\n    }\n  ]\n}"
    },

    {
      "section": "table",
      "caption": "Urutan Load — 8 File, 4 Layer",
      "content": [
        { "Urutan": "1", "File": "svg.css",   "Layer": "SVG",    "Kenapa": "Style .di-svg dan animasi. Wajib sebelum body render." },
        { "Urutan": "2", "File": "donat.css", "Layer": "Core",   "Kenapa": "Design token :root, grid, semua komponen dasar." },
        { "Urutan": "3", "File": "skin.css",  "Layer": "Skin",   "Kenapa": "Token fallback, sidebar, layout mode CSS." },
        { "Urutan": "4", "File": "skin.js",   "Layer": "Skin",   "Kenapa": "Auto Theme.init() — wajib sebelum donat.js agar token siap." },
        { "Urutan": "5", "File": "donat.js",  "Layer": "Core",   "Kenapa": "Kernel `d` — wajib sebelum ui.js dan kit modules." },
        { "Urutan": "6", "File": "ui.js",     "Layer": "UI",     "Kenapa": "Router + render engine + state." },
        { "Urutan": "7", "File": "svg.js",    "Layer": "SVG",    "Kenapa": "Icon engine. refreshIcons() dipanggil setelah setiap render." },
        { "Urutan": "8", "File": "login.js",  "Layer": "Kit",    "Kenapa": "Auto-init login.controller.login(). Butuh d, ui, svg." }
      ]
    },

    {
