    {
      "section": "code",
      "caption": "Spec-Driven Development — Dari Nol ke Produksi",
      "lang": "js",
      "colorPreset": "github-dark",
      "code": "// Alur kerja DonatJS — 5 fase:\n\n// FASE 1: Tulis JSON halaman (tanpa kode JS)\n// data/web/page/home.json → { page, data:[{section, content}] }\n\n// FASE 2: Daftarkan controller minimal\nwindow.web = {\n  controller: {\n    page: (id) => ui.render.page(config.getdata(id))\n  }\n};\n\n// FASE 3: Tambahkan menu di HTML\n// <li data-info=\"web/page/home\">Home</li>\n\n// FASE 4: Aktifkan interaktivitas\n// Di JSON: { \"control\":\"multi\", \"filter\":\"kategori,status\" }\n// → search + filter + paging otomatis, tanpa kode JS\n\n// FASE 5: Hubungkan API\n// config.api = 1;\n// app.host = 'https://api.saya.com/index.php';\n// d.service.create/update/delete siap dipakai\n\n// Hasil: aplikasi CRUD produksi\n// Tanpa: npm, webpack, virtual DOM, TypeScript wajib"
    },

